ler (a);
ler (b);
ler (c);
se (a <= 0 || b <= 0 || c <= 0) entao
    escrever ("Erro");
senao
    se (a + b > c && a + c > b && b + c > a) entao
        se a == b && b == c então
            escrever "Triângulo Equilátero";
        senão
            se a == b || a == c || b == c então
                escrever "Triângulo Isósceles";
            senão
                escrever "Triângulo Escaleno";
            fim
        fim
    senão
        escrever "Medidas inválidas";
    fim
fim
